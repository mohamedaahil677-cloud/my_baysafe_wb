# ──────────────────────────────────────────────────────────
# BaySafe DMS – Environment Variables Template
# Copy this file to .env and fill in your actual values.
# ──────────────────────────────────────────────────────────

# Flask secret key (change this for production!)
SECRET_KEY=change-me-to-a-random-secret

# ── Twilio SMS OTP ──────────────────────────────────────
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
# Must be a Twilio phone number with SMS capability, e.g. +1XXXXXXXXXX
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Without Twilio (Dev Mode) ───────────────────────────
# If TWILIO_ACCOUNT_SID is not set or is "your_account_sid",
# the server will run in mock mode: OTP is printed to console
# and returned in the API response as "mock_otp" for easy testing.
